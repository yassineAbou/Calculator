<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1e1e"
    tools:context=".Controller.MainActivity">

    <TextView
        android:id="@+id/activity_current_input"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center_horizontal"
        android:textColor="#ffffff"
        android:textSize="25dp"/>

    <TextView
        android:id="@+id/layout_result_output"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintTop_toBottomOf ="@+id/activity_current_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:textDirection="rtl"
        android:gravity="center_horizontal"
        android:textColor="#ffffff"
        android:textSize="50dp"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_ac_btn"
        android:layout_width="150dp"
        android:layout_height="75dp"
        android:background="@drawable/zero"
        android:backgroundTint="#f0f0f0"
        app:layout_constraintTop_toBottomOf = "@+id/layout_result_output"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:text="AC"
        android:textSize="20dp"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_back_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        android:backgroundTint="#f0f0f0"
        app:layout_constraintTop_toBottomOf = "@+id/layout_result_output"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="DEL"
        android:textSize="20dp"
        app:layout_constraintLeft_toRightOf = "@+id/layout_ac_btn"
        />



    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_division_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:background="@drawable/custom_button"
        android:backgroundTint="#f99c14"
        android:text="÷"
        android:textColor="#ffffff"
        android:textSize="20dp"
        app:layout_constraintLeft_toRightOf="@+id/layout_back_btn"
        app:layout_constraintTop_toBottomOf="@+id/layout_result_output" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_7_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_ac_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:text="7"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_8_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_ac_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="8"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf =  "@+id/layout_7_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_9_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_ac_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="9"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf =  "@+id/layout_8_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_multiplication_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_ac_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="×"
        android:textSize="20dp"
        app:layout_constraintLeft_toRightOf = "@+id/layout_9_btn"
        android:textColor="#ffffff"
        android:backgroundTint="#f99c14"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_4_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_7_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:text="4"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_5_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_7_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="5"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf = "@+id/layout_4_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_6_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_7_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="6"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf = "@+id/layout_5_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_subtraction_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_7_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text=" −"
        android:textSize="20dp"
        android:paddingLeft="-10dp"
        app:layout_constraintLeft_toRightOf = "@+id/layout_6_btn"
        android:textColor="#ffffff"
        android:backgroundTint="#f99c14"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_1_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_4_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:text="1"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_2_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_4_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="2"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf = "@+id/layout_1_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_3_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_4_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="3"
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf = "@+id/layout_2_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_sum_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_4_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="+"
        android:textSize="20dp"
        app:layout_constraintLeft_toRightOf = "@+id/layout_3_btn"
        android:textColor="#ffffff"
        android:backgroundTint="#f99c14"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_0_btn"
        android:layout_width="150dp"
        android:layout_height="75dp"
        android:background="@drawable/zero"
        app:layout_constraintTop_toBottomOf = "@+id/layout_1_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="20dp"
        android:text="0"
        android:textSize="20dp"
        android:paddingLeft="-60dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintStart_toStartOf="parent"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_dot_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_1_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text=","
        android:textSize="20dp"
        android:backgroundTint="#6c6c6d"
        android:textColor="#ffffff"
        app:layout_constraintLeft_toRightOf = "@+id/layout_0_btn"
        />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/layout_equal_btn"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:background="@drawable/custom_button"
        app:layout_constraintTop_toBottomOf = "@+id/layout_1_btn"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="5dp"
        android:text="="
        android:textSize="20dp"
        app:layout_constraintLeft_toRightOf = "@+id/layout_dot_btn"
        android:textColor="#ffffff"
        android:backgroundTint="#f99c14"
        />




</androidx.constraintlayout.widget.ConstraintLayout>